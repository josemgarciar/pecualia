# Infraestructura local
POSTGRES_DB=livestock
POSTGRES_USER=livestock
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Backend
ConnectionStrings__Postgres=Host=127.0.0.1;Port=5432;Database=livestock;Username=livestock;Password=change_me
Jwt__Issuer=Pecualia.Api
Jwt__Audience=Pecualia.Frontend
Jwt__SigningKey=replace_with_a_long_random_secret
Jwt__ExpirationMinutes=720
Activation__BaseUrl=http://127.0.0.1:5173/activate-account
Activation__TokenHours=72
Frontend__Origin=http://127.0.0.1:5173
Backend__PublicBaseUrl=http://127.0.0.1:5044

# Email
# File para desarrollo local, SMTP o proveedor propio cuando se conecte email real.
Email__Mode=File
Email__From=no-reply@example.com
Email__ReplyTo=soporte@example.com
Email__SmtpHost=
Email__SmtpPort=25
Email__SmtpUsername=
Email__SmtpPassword=
Email__ApiKey=
Email__WebhookSecret=
Email__PickupDirectory=App_Data/outbox

# Frontend / Vite
VITE_FRONTEND_HOST=127.0.0.1
VITE_FRONTEND_PORT=5173
VITE_FRONTEND_PREVIEW_PORT=4173
VITE_API_PROXY_TARGET=http://127.0.0.1:5044
VITE_HEALTH_PROXY_TARGET=http://127.0.0.1:5044
VITE_PUBLIC_APP_URL=http://127.0.0.1:5173

# Futuras integraciones cercanas
Stripe__PublishableKey=
Stripe__SecretKey=
Stripe__WebhookSecret=
